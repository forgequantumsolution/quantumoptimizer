# ─────────────────────────────────────────────────────────────────────────────
# Quantum Optimizer — Environment Variable Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development          # development | production | test
APP_VERSION=1.0.0             # injected by CI at build time

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# In production use a connection pooler (PgBouncer) URL.
DATABASE_URL=postgresql://qo_user:CHANGE_ME@localhost:5432/quantum_optimizer

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used for: session storage, rate limiting counters, BullMQ job queues
REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://:CHANGE_ME@your-redis-host:6380  # TLS form for prod

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 64 hex chars (256-bit entropy). Rotate every 90 days.
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64_different
JWT_ACCESS_EXPIRY=15m          # short-lived (15 min)
JWT_REFRESH_EXPIRY=30d

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Exact origin(s) allowed by CORS — no trailing slash, no wildcard
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://app.quantumoptimizer.io  # production

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_WINDOW_MS=60000     # 1 minute
RATE_LIMIT_AUTH_MAX=10              # 10 login attempts per minute per IP
RATE_LIMIT_API_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_API_MAX=1000             # 1000 API calls per 15 min per IP

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Used for: password resets, demo request acknowledgements
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
FROM_EMAIL=noreply@yourorgdomain.com

# ─── External Integrations ────────────────────────────────────────────────────
# Only set the connectors your deployment uses
ERP_BASE_URL=https://your-erp-instance.example.com
ERP_API_KEY=CHANGE_ME
CRM_ACCESS_TOKEN=CHANGE_ME
WMS_API_URL=https://your-wms.example.com
WMS_API_KEY=CHANGE_ME
POS_WEBHOOK_SECRET=CHANGE_ME      # HMAC secret for POS webhook validation
IOT_MQTT_BROKER=mqtts://your-broker.example.com
MARKET_DATA_API_KEY=CHANGE_ME     # Open-Meteo is free/keyless; others need key

# ─── Observability ────────────────────────────────────────────────────────────
# LOG_LEVEL=info                  # debug | info | warn | error
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces

# ─── Security ─────────────────────────────────────────────────────────────────
# ENCRYPTION_KEY=                 # AES-256-GCM key for PII at-rest (32 bytes hex)
# GITLEAKS_LICENSE_KEY=           # Only needed for enterprise gitleaks
