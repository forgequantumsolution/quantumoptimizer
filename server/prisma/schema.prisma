generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String      @id @default(cuid())
  name        String
  industry    Industry
  ssoConfig   Json?
  mfaRequired Boolean     @default(true)
  dataRegion  String
  users       User[]
  skus        SKU[]
  warehouses  Warehouse[]
  createdAt   DateTime    @default(now())
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  password   String
  firstName  String
  lastName   String
  role       Role
  department String?
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  isActive   Boolean    @default(true)
  lastLogin  DateTime?
  auditLogs  AuditLog[]
  createdAt  DateTime   @default(now())

  @@index([tenantId, isActive])
  @@index([tenantId, role])
}

model SKU {
  id        String      @id @default(cuid())
  code      String
  name      String
  category  String
  unit      String
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  inventory Inventory[]
  forecasts Forecast[]
  alerts    Alert[]
}

model Warehouse {
  id        String      @id @default(cuid())
  name      String
  location  String
  region    String
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  inventory Inventory[]
}

model Inventory {
  id          String    @id @default(cuid())
  skuId       String
  sku         SKU       @relation(fields: [skuId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  quantity    Float
  stockDays   Float
  expiryDate  DateTime?
  batchNumber String?
  updatedAt   DateTime  @updatedAt
}

model Forecast {
  id           String   @id @default(cuid())
  skuId        String
  sku          SKU      @relation(fields: [skuId], references: [id])
  warehouseId  String
  forecastDate DateTime
  horizon      Int
  demandValue  Float
  confidence   Float
  modelUsed    String
  isOverridden Boolean  @default(false)
  overrideVal  Float?
  overrideBy   String?
  overrideNote String?
  createdAt    DateTime @default(now())
}

model Alert {
  id          String        @id @default(cuid())
  skuId       String?
  sku         SKU?          @relation(fields: [skuId], references: [id])
  warehouseId String?
  severity    Severity
  category    AlertCategory
  title       String
  message     String
  isResolved  Boolean       @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([isResolved, severity])
  @@index([createdAt])
}

model ReplenishmentOrder {
  id          String      @id @default(cuid())
  skuId       String
  warehouseId String
  quantity    Float
  isAutomatic Boolean
  status      OrderStatus
  approvedBy  String?
  erpRef      String?
  createdAt   DateTime    @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
}

model Scenario {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        String
  parameters  Json
  results     Json?
  createdBy   String
  createdAt   DateTime @default(now())
}

enum Role {
  RETAILER
  DISTRIBUTOR_MANAGER
  SUPPLY_PLANNER
  PRODUCTION_MANAGER
  FINANCE
  SUPER_ADMIN
}

enum Industry {
  PHARMA
  FNB
  FMCG
}

enum Severity {
  CRITICAL
  WARNING
  INFO
}

enum AlertCategory {
  STOCKOUT_RISK
  EXPIRY
  OVERSTOCK
  SUPPLIER_DELAY
  AI_PLAN_READY
}

enum OrderStatus {
  PENDING
  AUTO_APPROVED
  HUMAN_APPROVED
  OVERRIDDEN
  DISPATCHED
}

model DataQualityIssue {
  id          String    @id @default(cuid())
  tenantId    String
  source      String
  sourceType  String
  recordId    String
  field       String
  issueType   String
  rawValue    String
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId, resolved])
  @@index([tenantId, source])
}

model ConnectorSyncLog {
  id              String   @id @default(cuid())
  tenantId        String
  connectorName   String
  sourceType      String
  recordsTotal    Int
  recordsInserted Int
  qualityIssues   Int
  qualityScore    Int
  durationMs      Int
  status          String   // SUCCESS | ERROR
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([tenantId, connectorName])
  @@index([tenantId, createdAt])
}

model DemandHistory {
  id         String   @id @default(cuid())
  tenantId   String
  itemId     String
  locationId String
  date       DateTime
  quantity   Float
  revenue    Float?
  currency   String   @default("INR")
  uom        String   @default("UNIT")
  channel    String   @default("DIRECT")
  promoFlag  Boolean  @default(false)
  source     String   @default("MANUAL")
  createdAt  DateTime @default(now())

  @@unique([itemId, locationId, date, channel])
  @@index([tenantId, itemId])
  @@index([tenantId, date])
  @@index([tenantId, locationId])
}

model ForecastResult {
  id           String   @id @default(cuid())
  tenantId     String
  itemId       String
  locationId   String
  forecastDate DateTime
  horizon      Int
  pointForecast Float
  lower80      Float
  upper80      Float
  lower95      Float
  upper95      Float
  modelUsed    String   // HOLT_WINTERS | SARIMA | XGBOOST | ENSEMBLE
  confidenceScore Float  @default(0.85)
  driver1      String?
  driver2      String?
  driver3      String?
  isOverridden Boolean  @default(false)
  overrideValue Float?
  overrideBy   String?
  overrideNote String?
  overrideAt   DateTime?
  createdAt    DateTime @default(now())

  @@unique([tenantId, itemId, locationId, forecastDate, modelUsed])
  @@index([tenantId, itemId, locationId])
  @@index([tenantId, forecastDate])
}

model ForecastAccuracy {
  id          String   @id @default(cuid())
  tenantId    String
  itemId      String
  locationId  String
  modelUsed   String
  periodEnd   DateTime
  mape        Float
  wmape       Float
  bias        Float
  fva         Float    @default(0)  // Forecast Value Added vs naive
  sampleSize  Int
  createdAt   DateTime @default(now())

  @@index([tenantId, modelUsed])
  @@index([tenantId, itemId])
  @@index([tenantId, periodEnd])
}

model PromoCalendar {
  id          String   @id @default(cuid())
  tenantId    String
  itemId      String?  // null = applies to all items
  locationId  String?  // null = applies to all locations
  name        String
  startDate   DateTime
  endDate     DateTime
  upliftPct   Float    @default(0)
  channel     String   @default("ALL")
  createdBy   String
  createdAt   DateTime @default(now())

  @@index([tenantId, startDate, endDate])
}

// ─── Phase 3: Consensus Demand Planning ──────────────────────────────────────

model PlanVersion {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  periodStart DateTime
  periodEnd   DateTime
  status      PlanStatus   @default(DRAFT)
  baselineId  String?      // parent version this was forked from
  createdBy   String
  submittedAt DateTime?
  submittedBy String?
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewNote  String?
  cells       PlanCell[]
  approvals   PlanApproval[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model PlanCell {
  id             String          @id @default(cuid())
  planVersionId  String
  planVersion    PlanVersion     @relation(fields: [planVersionId], references: [id])
  itemId         String
  locationId     String
  periodLabel    String          // e.g. "2026-W15"
  periodDate     DateTime        // Monday of the week
  statForecast   Float           // AI model value (immutable reference)
  consensusValue Float           // editable by demand planner
  priorValue     Float?          // value from baseline version for diff
  revenueImpact  Float?          // (consensusValue - statForecast) × avg price
  editedBy       String?
  editedAt       DateTime?
  comments       PlanCellComment[]
  createdAt      DateTime        @default(now())

  @@unique([planVersionId, itemId, locationId, periodLabel])
  @@index([planVersionId, itemId])
  @@index([planVersionId, periodLabel])
}

model PlanCellComment {
  id        String   @id @default(cuid())
  cellId    String
  cell      PlanCell @relation(fields: [cellId], references: [id])
  userId    String
  userEmail String
  userName  String
  body      String
  createdAt DateTime @default(now())

  @@index([cellId])
}

model PlanApproval {
  id            String      @id @default(cuid())
  planVersionId String
  planVersion   PlanVersion @relation(fields: [planVersionId], references: [id])
  action        String      // SUBMITTED | APPROVED | REJECTED
  userId        String
  userEmail     String
  userName      String
  note          String?
  createdAt     DateTime    @default(now())

  @@index([planVersionId])
}

enum PlanStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  LOCKED
}
